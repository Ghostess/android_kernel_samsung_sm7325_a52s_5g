#!/sbin/sh
# Shell Script EDIFY Replacement: Recovery Flashable Zip
# Credits to: osm0sis, salvogiangri, Simon1511, RisenID, Frax3r, saadelasfur
# See https://github.com/bone-machine/android_kernel_samsung_sm7325_a52s_5g

OUTFD=/proc/self/fd/$2;
ZIPFILE="$3";
TMPDIR="/tmp/rios";

package_extract_dir() {
  local entry outfile;
  for entry in $(unzip -l "$ZIPFILE" 2>/dev/null | tail -n+4 | grep -v '/$' | grep -o " $1.*$" | cut -c2-); do
    outfile="$(echo "$entry" | sed "s|${1}|${2}|")";
    mkdir -p "$(dirname "$outfile")";
    unzip -o "$ZIPFILE" "$entry" -p > "$outfile";
  done;
}

ui_print() {
  while [ "$1" ]; do
    echo -e "ui_print $1
      ui_print" >> $OUTFD;
    shift;
  done;
}

set_metadata() {
  local file i;
  file="$1";
  shift;
  while [ "$2" ]; do
    case $1 in
      uid) chown $2 "$file";;
      gid) chown :$2 "$file";;
      mode) chmod $2 "$file";;
      selabel)
        for i in /system/bin/toybox /system/toolbox /system/bin/toolbox; do
          (LD_LIBRARY_PATH=/system/lib64 $i chcon -h $2 "$file" || LD_LIBRARY_PATH=/system/lib64 $i chcon $2 "$file") 2>/dev/null;
        done || chcon -h $2 "$file" || chcon $2 "$file";
      ;;
      *) ;;
    esac;
    shift 2;
  done;
}

set_metadata_recursive() {
  local dir i;
  dir="$1";
  shift;
  while [ "$2" ]; do
    case $1 in
      uid) chown -R $2 "$dir";;
      gid) chown -R :$2 "$dir";;
      dmode) find "$dir" -type d -exec chmod $2 {} +;;
      fmode) find "$dir" -type f -exec chmod $2 {} +;;
      selabel)
        for i in /system/bin/toybox /system/toolbox /system/bin/toolbox; do
          (find "$dir" -exec LD_LIBRARY_PATH=/system/lib64 $i chcon -h $2 {} + || find "$dir" -exec LD_LIBRARY_PATH=/system/lib64 $i chcon $2 {} +) 2>/dev/null;
        done || find "$dir" -exec chcon -h $2 '{}' + || find "$dir" -exec chcon $2 '{}' +;
      ;;
      *) ;;
    esac;
    shift 2;
  done;
}

is_mounted() { mount | grep -qE "$1"; }

write_raw_image() { dd if="$1" of="$2"; }

set_progress() { echo "set_progress $1" >> $OUTFD; }

abort() {
  ui_print " ";
  ui_print "$1";
  ui_print "Installation aborted.";
  rm -rf "$TMPDIR";
  exit 1;
}

ui_print " ";
ui_print "    __                                    ";
ui_print "   / /_  ____  ____  ___                  ";
ui_print "  / __ \/ __ \/ __ \/ _ \                 ";
ui_print " / /_/ / /_/ / / / /  __/__    _          ";
ui_print "/_.___/\____/_/_/_/\___// /_  (_)___  ___ ";
ui_print "  / __ \`__ \/ __ \`/ ___/ __ \/ / __ \/ _ \\";
ui_print " / / / / / / /_/ / /__/ / / / / / / /  __/";
ui_print "/_/ /_/ /_/\__,_/\___/_/ /_/_/_/ /_/\___/ ";
ui_print "                                          ";
ui_print "##########################################";
ui_print " ";
ui_print "Device:     Samsung Galaxy A52s 5G";
ui_print "Codename:   a52sxq";
ui_print "Root:       KernelSU-Next v3.2.0-legacy";
ui_print "ROM:        AOSP";
ui_print "Kernel:     Linux 5.4.289";
ui_print "Compiler:   Clang 19";
ui_print "Build date: 2026-06-04";
ui_print " ";
ui_print "Special thanks to salvogiangri, Simon1511,";
ui_print "Frax3r, RisenID, and saadelasfur!";
ui_print " ";
ui_print "##########################################";
ui_print " ";
set_progress 0

if ! getprop ro.boot.bootloader | grep -qE "A528"; then
  abort "Unsupported device. This kernel is for A52s 5G only."
fi

ui_print "- Extracting images...";
mkdir -p "$TMPDIR";
package_extract_dir "images" "$TMPDIR/" || abort "Failed to extract images.";
set_progress 10;

ui_print "- Verifying images...";
for img in boot.img dtbo.img vendor_boot.img; do
  [ -f "$TMPDIR/$img" ] || abort "Missing image: $img"
done
set_progress 20;

ui_print "- Flashing boot.img";
write_raw_image "$TMPDIR/boot.img" "/dev/block/bootdevice/by-name/boot" || abort "Failed to flash boot.img";
set_progress 30;

ui_print "- Flashing dtbo.img";
write_raw_image "$TMPDIR/dtbo.img" "/dev/block/bootdevice/by-name/dtbo" || abort "Failed to flash dtbo.img";
set_progress 50;

ui_print "- Flashing vendor_boot.img";
write_raw_image "$TMPDIR/vendor_boot.img" "/dev/block/bootdevice/by-name/vendor_boot" || abort "Failed to flash vendor_boot.img";
set_progress 70;

ui_print "- Finalizing installation...";
rm -rf "$TMPDIR";
set_progress 90;

ui_print " ";
ui_print "Installation complete.";
ui_print " ";
ui_print "### IMPORTANT! ###";
ui_print " ";
ui_print "- If this is your first time flashing the kernel,";
ui_print "  make sure to wipe Cache/Dalvik. Otherwise, you can skip this step.";
ui_print " ";
ui_print "- If you are upgrading from a much older version of KernelSU-Next,";
ui_print "  completely uninstall your current manager app before installing v3.2.0 manager app.";
ui_print " ";
ui_print "- First boot may take longer than usual.";
ui_print " ";
set_progress 100;
